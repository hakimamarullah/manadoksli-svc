# ── OCR ──────────────────────────────────────────────
OCR_API_KEY=

# ── Elasticsearch ─────────────────────────────────────
ELASTICSEARCH_URI=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Storage (RustFS/MinIO) ────────────────────────────
STORAGE_ENDPOINT=http://host.docker.internal:9000
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=manadoksli
STORAGE_PUBLIC_URL=http://localhost:9000

# ── Spring ────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=local
SPRING_CLOUD_CONFIG_URI=http://host.docker.internal:9090
SPRING_APPLICATION_NAME=manadoksli-svc
LOG_FILE_PATH=/opt/app/logs
